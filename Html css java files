:root {
  --olive: #515A47;
  --gold: #D7BE82;
  --brown: #7A4419;
  --mustard: #755C1B;
  --wine: #400406;
  --white: #ffffff;
  --cream: #f8f5ee;
  --text: #222222;
  --muted: #666666;
  --border: #e6dfd1;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: Arial, Helvetica, sans-serif;
  color: var(--text);
  background: var(--white);
  line-height: 1.6;
}

body.modal-open,
body.cart-open {
  overflow: hidden;
}

img {
  max-width: 100%;
  display: block;
}

a {
  text-decoration: none;
  color: inherit;
}

button {
  font-family: inherit;
}

.container {
  width: 90%;
  max-width: 1280px;
  margin: 0 auto;
}

.section {
  padding: 60px 0;
}

.topbar {
  background: var(--wine);
  color: var(--white);
  text-align: center;
  padding: 12px 15px;
  font-size: 14px;
  font-weight: 700;
}

.site-header {
  background: var(--white);
  border-bottom: 1px solid var(--border);
}

.header-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  padding: 18px 0;
  flex-wrap: wrap;
}

.logo-box {
  display: flex;
  align-items: center;
  gap: 12px;
}

.logo-img {
  width: 72px;
  height: 72px;
  object-fit: cover;
  border-radius: 50%;
  border: 3px solid var(--gold);
}

.logo-text h1 {
  font-size: 24px;
  font-weight: 800;
  line-height: 1;
  color: var(--wine);
}

.logo-text p {
  font-size: 12px;
  letter-spacing: 2px;
  color: var(--olive);
  margin-top: 4px;
  font-weight: 700;
}

.menu-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 8px;
}

.menu-toggle span {
  width: 28px;
  height: 3px;
  background: var(--wine);
  border-radius: 2px;
}

.search-box {
  display: flex;
  flex: 1;
  max-width: 520px;
  min-width: 260px;
}

.search-box input {
  flex: 1;
  padding: 14px 16px;
  border: 1px solid var(--border);
  border-right: none;
  outline: none;
  font-size: 14px;
}

.search-box button {
  border: none;
  background: var(--olive);
  color: var(--white);
  padding: 0 22px;
  cursor: pointer;
  font-weight: 700;
}

.header-actions {
  display: flex;
  gap: 18px;
  font-size: 14px;
  font-weight: 700;
  color: var(--brown);
  align-items: center;
}

.cart-button {
  border: none;
  background: var(--wine);
  color: var(--white);
  padding: 10px 16px;
  border-radius: 999px;
  cursor: pointer;
  font-weight: 700;
}

.main-nav {
  border-bottom: 1px solid var(--border);
  background: var(--cream);
}

.nav-wrap {
  display: flex;
  gap: 24px;
  overflow-x: auto;
  white-space: nowrap;
  padding: 14px 0;
}

.nav-wrap a {
  font-size: 14px;
  font-weight: 700;
  color: var(--olive);
}

.hero {
  background: linear-gradient(135deg, #f8f5ee, #efe7d3);
  padding: 70px 0;
}

.hero-content {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 40px;
  align-items: center;
}

.eyebrow {
  display: inline-block;
  background: var(--wine);
  color: var(--white);
  padding: 7px 12px;
  font-size: 12px;
  border-radius: 999px;
  margin-bottom: 18px;
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 700;
}

.hero-text h2 {
  font-size: 46px;
  line-height: 1.1;
  margin-bottom: 18px;
  color: var(--wine);
}

.hero-text p {
  font-size: 16px;
  color: var(--muted);
  max-width: 560px;
}

.hero-buttons {
  margin-top: 28px;
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}

.btn {
  display: inline-block;
  padding: 14px 24px;
  border-radius: 6px;
  font-weight: 700;
  font-size: 14px;
  transition: 0.3s ease;
  border: none;
  cursor: pointer;
}

.btn-dark {
  background: var(--olive);
  color: var(--white);
}

.btn-dark:hover {
  background: var(--wine);
}

.btn-light {
  background: var(--gold);
  color: var(--wine);
  border: 1px solid var(--gold);
}

.btn-light:hover {
  background: var(--brown);
  color: var(--white);
}

.hero-image img {
  width: 100%;
  max-height: 520px;
  object-fit: cover;
  border-radius: 22px;
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.08);
}

.section-heading {
  text-align: center;
  margin-bottom: 35px;
}

.section-heading h2 {
  font-size: 32px;
  margin-bottom: 10px;
  color: var(--wine);
}

.section-heading p {
  color: var(--muted);
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 18px;
}

.category-card {
  background: var(--cream);
  border: 1px solid var(--border);
  padding: 30px 20px;
  text-align: center;
  font-weight: 700;
  border-radius: 12px;
  transition: 0.3s ease;
  color: var(--olive);
}

.category-card:hover {
  transform: translateY(-4px);
  background: var(--gold);
  color: var(--wine);
}

.shop-layout {
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 30px;
}

.filters {
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 22px;
  background: var(--cream);
  height: fit-content;
  position: sticky;
  top: 20px;
}

.filters h3 {
  font-size: 22px;
  margin-bottom: 20px;
  color: var(--wine);
}

.filter-group {
  margin-bottom: 24px;
}

.filter-group h4 {
  font-size: 16px;
  margin-bottom: 12px;
  color: var(--olive);
}

.filter-group label {
  display: block;
  margin-bottom: 10px;
  color: var(--muted);
  font-size: 14px;
}

.product-topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20px;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.product-topbar h2 {
  font-size: 30px;
  color: var(--wine);
}

.product-topbar select {
  padding: 12px 14px;
  border: 1px solid var(--border);
  background: var(--white);
  font-family: Arial, Helvetica, sans-serif;
}

.bundle-banner {
  background: var(--gold);
  color: var(--wine);
  padding: 18px 20px;
  border-radius: 12px;
  margin-bottom: 24px;
}

.bundle-banner h3 {
